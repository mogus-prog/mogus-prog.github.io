---
const navLinks = [
  {
    label: "Loan Programs",
    href: "/loans",
    children: [
      { label: "Conventional Loans", href: "/loans/conventional" },
      { label: "FHA Loans", href: "/loans/fha" },
      { label: "VA Loans", href: "/loans/va" },
      { label: "USDA Loans", href: "/loans/usda" },
      { label: "Jumbo Loans", href: "/loans/jumbo" },
      { label: "Refinance", href: "/loans/refinance" },
      { label: "First-Time Buyer", href: "/loans/first-time-buyer" },
    ],
  },
  { label: "Calculators", href: "/tools/mortgage-calculator" },
  { label: "Resources", href: "/resources" },
  { label: "About", href: "/company/about" },
];
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-4">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src={`${import.meta.env.BASE_URL}logo-white.svg`} alt="Intra Mortgage" class="h-10 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <div class="relative group">
            <a
              href={link.href}
              class="text-sm text-white/80 hover:text-white transition-colors flex items-center gap-1"
            >
              {link.label}
              {link.children && (
                <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.children && (
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="glass-strong rounded-xl py-2 min-w-[220px] shadow-xl">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Right side -->
      <div class="hidden lg:flex items-center gap-5">
        <a href="tel:+18005550199" class="text-sm text-white/80 hover:text-white transition-colors flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (800) 555-0199
        </a>
        <a
          href="/apply"
          class="bg-cyan-500 hover:bg-cyan-400 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors"
        >
          Apply Now
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-white p-2"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden glass-strong">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <>
          <a href={link.href} class="block py-3 px-3 text-white/80 hover:text-white text-base font-medium rounded-lg hover:bg-white/5">
            {link.label}
          </a>
          {link.children && link.children.map((child) => (
            <a href={child.href} class="block py-2 px-6 text-white/50 hover:text-white text-sm rounded-lg hover:bg-white/5">
              {child.label}
            </a>
          ))}
        </>
      ))}
      <div class="pt-4 border-t border-white/10 space-y-3">
        <a href="tel:+18005550199" class="block py-2 px-3 text-white/80 text-sm">📞 (800) 555-0199</a>
        <a href="/apply" class="block bg-cyan-500 text-white text-center py-3 px-4 rounded-lg font-semibold">Apply Now</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-18"></div>

<script>
  // Nav background on scroll
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('bg-navy-950/90', 'backdrop-blur-xl', 'shadow-lg');
    } else {
      nav?.classList.remove('bg-navy-950/90', 'backdrop-blur-xl', 'shadow-lg');
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
