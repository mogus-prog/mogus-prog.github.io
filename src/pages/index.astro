---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatInput from '../components/ChatInput.tsx';
import MortgageCalculator from '../components/MortgageCalculator.tsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "MortgageBroker",
  "name": "Intra Mortgage",
  "url": "https://intramortgage.com",
  "telephone": "+1-800-555-0199",
  "areaServed": "US",
  "description": "Nationwide mortgage lending with personalized service. Compare rates, get pre-approved online, and close faster.",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "1250"
  }
};

const loanPrograms = [
  { title: "Conventional", desc: "As low as 3% down", href: "/loans/conventional", img: "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=400&h=260&fit=crop" },
  { title: "FHA Loans", desc: "3.5% down payment", href: "/loans/fha", img: "https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=400&h=260&fit=crop" },
  { title: "VA Loans", desc: "$0 down for veterans", href: "/loans/va", img: "https://images.unsplash.com/photo-1560440021-33f9b867899d?w=400&h=260&fit=crop" },
  { title: "Jumbo", desc: "High-value properties", href: "/loans/jumbo", img: "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400&h=260&fit=crop" },
];

const journeys = [
  {
    title: "I Want to Buy",
    emoji: "🏡",
    desc: "First home, next home, or investment property — let's find your perfect loan.",
    cta: "Explore Purchase Loans",
    href: "/loans",
    img: "https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=500&h=300&fit=crop"
  },
  {
    title: "I Want to Refinance",
    emoji: "🔄",
    desc: "Lower your rate, reduce your payment, or tap into your home's equity.",
    cta: "Check Refi Rates",
    href: "/loans/refinance",
    img: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=500&h=300&fit=crop"
  },
  {
    title: "I Have Questions",
    emoji: "💬",
    desc: "Not sure where to start? Talk to a friendly expert — zero pressure, zero cost.",
    cta: "Schedule a Free Call",
    href: "/company/contact",
    img: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=500&h=300&fit=crop"
  },
];

const steps = [
  {
    num: "1",
    title: "Tell Us Your Goals",
    desc: "Ask our AI assistant or fill out a quick form. Takes 3 minutes, no credit impact.",
    img: "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=500&h=320&fit=crop"
  },
  {
    num: "2",
    title: "Get Expert Guidance",
    desc: "Your dedicated loan officer reviews your options and finds the best rates for your situation.",
    img: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=500&h=320&fit=crop"
  },
  {
    num: "3",
    title: "Get Your Keys 🎉",
    desc: "We handle the paperwork and heavy lifting. You focus on picking out furniture for your new home.",
    img: "https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=500&h=320&fit=crop&crop=center"
  },
];

const testimonials = [
  {
    name: "Sarah Martinez",
    location: "First-Time Homebuyer • Austin, TX",
    text: "I was so nervous about buying my first home, but the team at Intra walked me through everything. They found me a rate I didn't think was possible, and I closed in just 22 days.",
    img: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=300&h=300&fit=crop&crop=face",
    featured: true,
  },
  {
    name: "James Rivera",
    location: "Refinance • California",
    text: "Refinanced and now saving $400/month. The process was shockingly easy.",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face",
    featured: false,
  },
  {
    name: "Michael Torres",
    location: "VA Loan • Florida",
    text: "As a veteran, the VA loan process was handled perfectly. Closed in 25 days with zero down.",
    img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=200&h=200&fit=crop&crop=face",
    featured: false,
  },
];

const blogPosts = [
  {
    category: "Buying Guide",
    title: "How Much House Can You Actually Afford in 2026?",
    readTime: "5 min read",
    href: "/resources/how-much-house-can-you-afford",
    img: "https://images.unsplash.com/photo-1560184897-ae75f418493e?w=500&h=320&fit=crop",
  },
  {
    category: "First-Time Buyers",
    title: "The Complete Guide to Buying Your First Home",
    readTime: "8 min read",
    href: "/resources/first-time-homebuyer-guide",
    img: "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=500&h=320&fit=crop",
  },
  {
    category: "Market Update",
    title: "Mortgage Rate Forecast: What Experts Are Saying",
    readTime: "4 min read",
    href: "/resources/mortgage-rate-forecast",
    img: "https://images.unsplash.com/photo-1434626881859-194d67b2b86f?w=500&h=320&fit=crop",
  },
];

const stats = [
  { value: "15,000+", label: "Families in Their Dream Homes" },
  { value: "4.9 ★", label: "Rated on Google & Zillow" },
  { value: "21 Days", label: "Average Time to Close" },
  { value: "50 States", label: "Licensed Nationwide" },
];
---

<BaseLayout title="Intra Mortgage — Find Your Perfect Mortgage Rate" schema={schema}>

  <!-- ==================== HERO ==================== -->
  <section id="chat" class="relative overflow-hidden -mt-18">
    <img
      src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1600&h=900&fit=crop&crop=center"
      alt="Couple in a collaborative discussion with mortgage professional at desk"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/80 to-navy-950/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 md:pt-44 md:pb-28">
      <div class="max-w-2xl">
        <img src={`${import.meta.env.BASE_URL}logo-white.svg`} alt="Intra Mortgage" class="h-16 md:h-20 w-auto mb-8" />
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-4">
          Your Journey Starts With a Question
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6">
          The Home You've<br />Been Dreaming Of<br />Is <span class="text-gradient">Within Reach</span>
        </h1>
        <p class="text-white/65 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
          Ask our AI mortgage assistant anything — rates, programs, what you can afford, how to get started. Get instant, personalized answers 24/7.
        </p>

        <ChatInput client:load variant="hero" />

        <div class="flex flex-wrap gap-5 mt-6 text-white/40 text-xs">
          <span>✓ Instant AI answers</span>
          <span>✓ No signup required</span>
          <span>✓ Connect to a human anytime</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TRUST BAR ==================== -->
  <section class="bg-navy-900 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0">
        {stats.map((stat, i) => (
          <div class={`text-center ${i < 3 ? 'md:border-r md:border-white/8' : ''}`}>
            <div class="text-cyan-500 text-2xl md:text-3xl font-extrabold">{stat.value}</div>
            <div class="text-white/45 text-xs mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== JOURNEY SELECTOR ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">How Can We Help?</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">What Brings You Here Today?</h2>
        <p class="text-white/45 text-sm mt-3">Choose your path and we'll personalize your experience</p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {journeys.map((j) => (
          <a href={j.href} class="group block rounded-2xl overflow-hidden border border-white/8 hover-card bg-white/[0.02]">
            <div class="overflow-hidden">
              <img src={j.img} alt={j.title} class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="text-white text-lg font-bold mb-1">{j.emoji} {j.title}</h3>
              <p class="text-white/45 text-sm leading-relaxed">{j.desc}</p>
              <p class="text-cyan-500 text-sm font-semibold mt-3 group-hover:translate-x-1 transition-transform">{j.cta} →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LOAN PROGRAMS ==================== -->
  <section class="section-padding bg-gradient-to-b from-navy-950 to-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Loan Programs</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">A Loan for Every Story</h2>
        <p class="text-white/45 text-sm mt-3">Every homeowner's journey is unique. We have the right program for yours.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {loanPrograms.map((loan) => (
          <a href={loan.href} class="group block rounded-xl overflow-hidden border border-white/6 hover-card bg-white/[0.02]">
            <div class="overflow-hidden">
              <img src={loan.img} alt={loan.title} class="w-full h-32 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-4 text-center">
              <h3 class="text-white text-sm font-bold">{loan.title}</h3>
              <p class="text-white/40 text-xs mt-1">{loan.desc}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/loans" class="text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors">
          View All Loan Programs →
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="section-padding bg-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">It's Easier Than You Think</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Three Steps to Your New Home</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {steps.map((step) => (
          <div class="text-center fade-up">
            <div class="relative rounded-2xl overflow-hidden mb-5">
              <img src={step.img} alt={step.title} class="w-full h-48 object-cover" loading="lazy" />
              <div class="absolute top-3 left-3 w-10 h-10 bg-cyan-500 rounded-xl flex items-center justify-center text-white text-lg font-extrabold shadow-lg">
                {step.num}
              </div>
            </div>
            <h3 class="text-white text-lg font-bold mb-2">{step.title}</h3>
            <p class="text-white/45 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/apply" class="inline-block bg-cyan-500 hover:bg-cyan-400 text-white text-sm font-bold px-10 py-4 rounded-xl transition-colors">
          Start Your Journey Today →
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== CALCULATOR ==================== -->
  <section class="section-padding bg-gradient-to-b from-navy-900 to-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="fade-up">
          <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">You Might Be Surprised</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">
            You Can Probably<br />Afford More Than<br />You Think
          </h2>
          <p class="text-white/50 text-sm leading-relaxed mb-6">
            Use our free calculator to see your estimated monthly payment. No signup required. Many of our borrowers are surprised how affordable homeownership really is.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-cyan-500/10 text-cyan-500 text-xs px-4 py-2 rounded-lg border border-cyan-500/20 font-medium">Mortgage Calculator</span>
            <a href="/tools/refinance-calculator" class="bg-white/[0.04] text-white/55 text-xs px-4 py-2 rounded-lg border border-white/8 hover:border-white/15 transition-colors">Refinance Savings</a>
            <a href="/tools/affordability-calculator" class="bg-white/[0.04] text-white/55 text-xs px-4 py-2 rounded-lg border border-white/8 hover:border-white/15 transition-colors">Affordability</a>
          </div>
        </div>
        <div class="fade-up">
          <MortgageCalculator client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section class="section-padding bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-up">
        <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Real Stories, Real People</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">They Did It. So Can You.</h2>
      </div>

      <!-- Featured testimonial -->
      {testimonials.filter(t => t.featured).map((t) => (
        <div class="glass rounded-2xl p-6 md:p-8 mb-5 fade-up">
          <div class="grid md:grid-cols-[200px_1fr] gap-6 items-center">
            <img src={t.img} alt={t.name} class="w-full h-52 md:h-full object-cover rounded-xl" loading="lazy" />
            <div>
              <div class="text-amber-400 text-sm mb-3">★★★★★</div>
              <p class="text-white/80 text-base md:text-lg leading-relaxed italic mb-4">"{t.text}"</p>
              <p class="text-white font-bold">{t.name}</p>
              <p class="text-white/40 text-sm">{t.location}</p>
            </div>
          </div>
        </div>
      ))}

      <!-- Smaller testimonials -->
      <div class="grid md:grid-cols-2 gap-4">
        {testimonials.filter(t => !t.featured).map((t) => (
          <div class="glass rounded-xl p-5 flex gap-4 fade-up">
            <img src={t.img} alt={t.name} class="w-14 h-14 rounded-xl object-cover flex-shrink-0" loading="lazy" />
            <div>
              <div class="text-amber-400 text-xs mb-1">★★★★★</div>
              <p class="text-white/70 text-sm leading-relaxed italic mb-2">"{t.text}"</p>
              <p class="text-white text-sm font-semibold">{t.name} <span class="text-white/30 font-normal">• {t.location}</span></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== BLOG / LEARNING CENTER ==================== -->
  <section class="section-padding bg-gradient-to-b from-navy-950 to-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-10 fade-up">
        <div>
          <p class="text-cyan-500 text-xs font-semibold tracking-[3px] uppercase mb-3">Learn & Feel Confident</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-white">Knowledge is Power</h2>
        </div>
        <a href="/resources" class="text-cyan-500 text-sm font-semibold hover:text-cyan-400 transition-colors hidden md:block">
          View All Articles →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {blogPosts.map((post) => (
          <a href={post.href} class="group block rounded-xl overflow-hidden border border-white/6 hover-card bg-white/[0.02]">
            <div class="overflow-hidden">
              <img src={post.img} alt={post.title} class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <p class="text-cyan-500 text-[10px] font-semibold uppercase tracking-wider">{post.category}</p>
              <h3 class="text-white text-sm font-semibold mt-2 leading-snug group-hover:text-cyan-400 transition-colors">{post.title}</h3>
              <p class="text-white/30 text-xs mt-3">{post.readTime}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8 md:hidden">
        <a href="/resources" class="text-cyan-500 text-sm font-semibold">View All Articles →</a>
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1600&h=500&fit=crop"
      alt="Beautiful home"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/92 to-cyan-600/88"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3">Still Have Questions?</h2>
      <p class="text-white/85 text-base mb-8">Our AI mortgage assistant is here 24/7. Ask anything — no signup, no pressure.</p>

      <ChatInput client:visible variant="cta" />

      <p class="text-white/60 text-sm mt-6">
        Or call us directly: <a href="tel:+18005550199" class="text-white font-bold hover:underline">(800) 555-0199</a>
      </p>
    </div>
  </section>

</BaseLayout>
